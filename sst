#!/bin/bash

# ==============================================================================
# S.S.T (Steam Soundtrack Tagger) Launcher
# ==============================================================================

# --- Configuration ---
MAIN_MODULE="sst.main"
export PYTHONPATH="src"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# --- Help Message ---
show_help() {
    echo -e "${BLUE}🚀 Project S.S.T Launcher${NC}"
    echo "Usage: ./sst [options]"
    echo ""
    echo "Basic Options:"
    echo "      --all          Process all unprocessed soundtracks (Requires 3 confirmations)."
    echo "  -n, --limit N      Process N unprocessed soundtracks."
    echo "  -f, --force        Force re-processing of already completed albums."
    echo "      --appid ID     Process only a specific Steam AppID."
    echo ""
    echo "Maintenance & Stats (Exclusive):"
    echo "      --finalize     Ingest corrected metadata from review folders (Requires 3 confirmations)."
    echo "      --delete-db    Reset the local database (Requires 3 confirmations)."
    echo "      --stats        Show processing statistics from the database."
    echo "      --logs [AppID] Browse processing history or show album details."
    echo ""
    echo "Debugging & Monitoring:"
    echo "      --dev          Run in Development Mode (DEBUG logs, keep temp files)."
    echo "      --tail         Watch the latest log file (tail -f)."
    echo "  -h, --help         Show this help message."
}

# --- Guard: No arguments ---
if [[ $# -eq 0 ]]; then
    show_help
    exit 0
fi

# --- Argument Parsing ---
CMD_ARGS=()
TAIL_MODE=false
STATS_MODE=false
LOGS_MODE=false
LOGS_APPID=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --all)
            CMD_ARGS+=("--all")
            shift
            ;;
        -n|--limit)
            CMD_ARGS+=("--limit" "$2")
            shift 2
            ;;
        -f|--force)
            CMD_ARGS+=("--force")
            shift
            ;;
        --appid)
            CMD_ARGS+=("--appid" "$2")
            shift 2
            ;;
        --finalize)
            CMD_ARGS+=("--finalize")
            shift
            ;;
        --delete-db)
            CMD_ARGS+=("--reset-db")
            shift
            ;;
        --stats)
            STATS_MODE=true
            shift
            ;;
        --logs)
            LOGS_MODE=true
            if [[ $2 =~ ^[0-9]+$ ]]; then
                LOGS_APPID="$2"
                shift 2
            else
                shift
            fi
            ;;
        --dev)
            CMD_ARGS+=("--dev")
            shift
            ;;
        --tail)
            TAIL_MODE=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            CMD_ARGS+=("$1")
            shift
            ;;
    esac
done

# --- Prerequisites Check ---
if ! command -v uv &> /dev/null; then
    echo -e "${RED}❌ Error: 'uv' not found in PATH.${NC}"
    echo "Please install uv: https://github.com/astral-sh/uv"
    exit 1
fi

# --- Reset Env (Ensure clean state from .env) ---
if [ -f ".env" ]; then
    while IFS='=' read -r key value; do
        if [[ ! "$key" =~ ^# && -n "$key" ]]; then unset "$key"; fi
    done < ".env"
fi

# --- Helper function to run with uv ---
run_uv() {
    # We use uv run to execute within the root project environment
    uv run python -u "$@"
}

# --- Exclusive Maintenance Modes ---

if [ "$STATS_MODE" = true ]; then
    echo -e "${BLUE}📊 S.S.T Processing Statistics${NC}"
    # Use grep to find DB path from .env if exists, otherwise default
    DB_PATH=$(grep "^SST_DB_PATH=" .env | cut -d'=' -f2)
    DB_PATH=${DB_PATH:-data/sst_local_state.db}
    
    if [ -f "$DB_PATH" ] && command -v sqlite3 &> /dev/null; then
        echo "--------------------------------"
        sqlite3 "$DB_PATH" "SELECT status, count(*) FROM processed_albums GROUP BY status;"
        echo "--------------------------------"
    else
        echo "No database found at $DB_PATH or sqlite3 not found."
    fi
    exit 0
fi

if [ "$LOGS_MODE" = true ]; then
    run_uv -m sst.log_browser $LOGS_APPID
    exit 0
fi

if [ "$TAIL_MODE" = true ]; then
    # Look for logs prefixed with SST_ (including DEBUG variants)
    LATEST_LOG=$(ls -t logs/SST_*.log 2>/dev/null | head -n 1)
    if [ -n "$LATEST_LOG" ]; then
        echo -e "${BLUE}📺 Monitoring latest log: $LATEST_LOG${NC}"
        tail -f "$LATEST_LOG"
    else
        echo -e "${RED}❌ No SST_*.log files found in logs/ directory.${NC}"
    fi
    exit 0
fi

# --- Main S.S.T Execution ---

# Ensure terminal is in a sane state
stty sane

echo -e "${GREEN}🚀 Starting S.S.T System (via uv)...${NC}"
run_uv -m $MAIN_MODULE "${CMD_ARGS[@]}"

# Restoration of terminal echo
stty echo

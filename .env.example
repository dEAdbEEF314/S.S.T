# ==============================================================================
# S.S.T (Steam Soundtrack Tagger) - Environment Variables Template
# ==============================================================================

# --- Storage (S3 / SeaweedFS) ---
# S3 compatible storage endpoint and credentials
S3_ENDPOINT_URL=http://localhost:8333
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=sst-data
S3_REGION=us-east-1

# --- Orchestration (Prefect) ---
# Connection settings for Prefect Core container
PREFECT_API_URL=http://localhost:4200/api
PREFECT_FLOW_NAME=SST-Production-Pipeline
# PREFECT_API_KEY=your_prefect_cloud_api_key (Optional: only if using Prefect Cloud)

# --- AI / LLM (OpenAI Compatible API) ---
# Used for title normalization and validation (Strict No-Guessing Policy)
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.0

# --- External Music Databases ---
# User Agent is mandatory for MusicBrainz API calls
# Format: Name/Version ( ContactEmail )
MUSICBRAINZ_USER_AGENT=SST/1.0.0 ( contact@example.com )

# AcoustID API Key (Optional: used as last resort fallback)
ACOUSTID_API_KEY=your_acoustid_api_key

# --- Steam Library (Scout Container) ---
# Path to the local Steam library (e.g., /mnt/e/SteamLibrary)
# This directory must contain 'steamapps/common' and ACF files.
STEAM_LIBRARY_PATH=/path/to/your/steamlibrary

# (Optional) Steam Web API Key
# Not required for public Store API, but useful for other services
# STEAM_API_KEY=your_steam_web_api_key

# --- Audio Constraints (Optional Overrides) ---
# Defaults: SampleRate=48000, Bitrate=320k
# MAX_SAMPLE_RATE=48000
# MP3_BITRATE=320k

# --- System & Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Environment mode: development, production
ENV_MODE=development

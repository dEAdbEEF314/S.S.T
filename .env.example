# ==============================================================================
# S.S.T (Steam Soundtrack Tagger) 統合設定ファイル
# ==============================================================================

# --- Steam 設定 ---
# Windows側のSteamライブラリのパス (WSL2からのマウントパス形式で指定)
STEAM_LIBRARY_PATH=/mnt/e/SteamLibrary
# メタデータ取得時の優先言語
STEAM_LANGUAGE=japanese

# --- ローカル処理設定 ---
# 変換やタグ付け作業を行うための一時ディレクトリ (WSL2のネイティブ領域を推奨)
SST_WORKING_DIR=/home/sexyroot/sst-work
# 処理状態を記録するSQLiteデータベースのパス
SST_DB_PATH=sst_local_state.db

# --- SeaweedFS / S3 設定 ---
# S3 API 経由（署名エラーが起きやすい、従来の用途）
S3_ENDPOINT_URL=http://swfs-s3.outergods.lan
# Filer API 経由（推奨。高速で署名エラーなし）
S3_FILER_URL=http://swfs-filer.outergods.lan
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=sst-data
S3_REGION=us-east-1

# --- LLM (Gemini/OpenAI-compatible) 設定 ---
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=your_api_key
LLM_MODEL=gemini-1.5-pro
# レート制限 (RPM: 分間リクエスト数, TPM: 分間トークン数, RPD: 日間リクエスト数)
LLM_LIMIT_RPM=30
LLM_LIMIT_TPM=15000
LLM_LIMIT_RPD=14400

# --- メタデータ優先順位 ---
# ソースの優先順位をカンマ区切りで指定します。
# MBZ: MusicBrainz, STEAM: Steam API, EMBEDDED: 音声ファイルの埋め込みタグ
METADATA_SOURCE_PRIORITY=MBZ,STEAM,EMBEDDED

# --- システム設定 ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
# Environment mode: development, production
ENV_MODE=development
# TimeZone
TZ=Asia/Tokyo

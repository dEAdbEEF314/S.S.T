# ==============================================================================
# S.S.T (Steam Soundtrack Tagger) 統合設定ファイル
# ==============================================================================

# --- Steam 設定 ---
# 【必須】Steam本体がインストールされているディレクトリ
# Windows形式 (C:\Program Files (x86)\Steam) または WSL形式 (/mnt/c/...) のどちらでも指定可能です。
# プログラム内部で自動的にWSL2環境のパスに変換されます。
STEAM_INSTALL_PATH=C:\Program Files (x86)\Steam

# 【オプション】特定ドライブのライブラリのみをスキャンしたい場合のみ指定。
# 指定がない場合、libraryfolders.vdf を自動解析して全ドライブのライブラリをスキャンします。
STEAM_LIBRARY_PATH=

# 処理済みファイルの出力先ディレクトリ
# ※現在、I/O負荷回避のためWindowsへの自動ZIP展開・転送機能は無効化されています。
# Ubuntu（WSL）上のディレクトリパス (例: /home/user/sst_output) を指定してください。
# 指定したディレクトリ内に archive/ と review/ フォルダが作成され、ZIPアーカイブのまま出力されます。
SST_OUTPUT_DIR=

# Steam dynamicstore からuserdata.json を自動取得するためのクッキー値
# ブラウザの開発者ツール(F12) → Application → Cookies → store.steampowered.com
# → "steamLoginSecure" の Value をコピーして貼り付ける
# 未設定の場合は data/userdata.json を手動配置する方式にフォールバック
STEAM_LOGIN_SECURE=

# Steam Web API Key (API呼び出しを強化する場合に使用)
# 取得: https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# Steam PICS Bridge URL (外部サーバーまたはローカルDocker)
# デフォルト: http://localhost:8080/v1/info/
STEAM_PICS_BRIDGE_URL=http://localhost:8080/v1/info/

# Steam PICS Bridge API Key (外部サーバーで認証が必要な場合のみ指定)
# 値が "Bearer " で始まる場合は Authorization ヘッダー、それ以外は X-API-Key ヘッダーで送信されます
STEAM_PICS_BRIDGE_API_KEY=

# 使用言語設定 (ja, en, zh-CN 等、ISO 639-1形式)
USER_LANGUAGE=ja


# --- ローカル処理設定 ---
# 変換やタグ付け作業を行うための一時ディレクトリ (WSL2のネイティブ領域を推奨)
SST_WORKING_DIR=/tmp/sst-work
# 処理状態を記録するSQLiteデータベースのパス
SST_DB_PATH=data/sst_local_state.db

# 並列処理設定 (FFmpeg変換などの音声処理の同時実行数)
MAX_ENCODING_TASKS=4

# LLM バックエンド設定 (OLLAMA | GEMINI | OPENAI_COMPATIBLE)
# OLLAMA: ローカルの Ollama を使用 (動的コンテキスト制御、Speculative Decoding 対応)
# GEMINI: Google AI Studio の Gemini API を使用
# OPENAI_COMPATIBLE: LM Studio, OpenAI 本家 等を使用
LLM_BACKEND=GEMINI
# ベースURL
# Ollama: http://localhost:11434
# Gemini: https://generativelanguage.googleapis.com
LLM_BASE_URL=https://generativelanguage.googleapis.com
LLM_API_KEY=your_api_key
LLM_MODEL=gemini-1.5-pro

# --- レート制限およびクラウドAPIコンテキスト制御 ---
# これらを適切に設定することで、APIの429エラー(Too Many Requests)を完全に防ぎつつ、
# アルバムのチャンク分割を限界まで減らしてLLMの推論精度(文脈理解)を最大化できます。
# 1分間に送信できる最大リクエスト数 (RPM)
LLM_LIMIT_RPM=15
# 1分間に送信できる最大トークン数 (TPM)。チャンクサイズ上限の動的計算に使用されます。
LLM_LIMIT_TPM=10000000
LLM_LIMIT_RPD=1500

# クラウドAPI利用時の「最大出力トークン数」(Max Output Tokens)
# Gemini 1.5 Pro等なら8192、OpenAI汎用モデルなら4096等、モデル固有の上限を指定します。
# ※この値とTPM制限から、One-shotで処理可能な限界チャンクサイズをシステムが自動算出します。
LLM_CLOUD_MAX_TOKENS=8192

# --- Ollama 出力/コンテキスト制御 ---
# 1リクエストで参照可能な最大コンテキストトークン。
# モデルの仕様（Llama3なら8192等）に合わせるのが基本ですが、大きくするほどVRAM(KVキャッシュ)を大量消費します。
# 並列実行数を増やしたい場合は、あえて 4096 や 8192 などの小さめの値に絞るチューニングが有効です。
LLM_OLLAMA_NUM_CTX=32768
# モデルへの信頼度（チャンクの天井）を表す最大出力トークン。
# 実際のAPIリクエストではリミッター解除(-1)を行いますが、この値は「モデルが幻覚を起こさず安全に長文出力できる限界の目安」
# としてチャンク分割の動的算出に使用されます。優秀な大型モデルなら8192、中小型なら4096以下を推奨します。
LLM_OLLAMA_NUM_PREDICT=4096

# Chunk 制御（LLM入力分割）
# 巨大アルバムとしてCoherence(階層型Map-Reduce)処理を発動する閾値（トラック数）
LLM_COHERENCE_THRESHOLD=75
# 一度に処理するローカルトラック数の基本単位（トークン制限回避）
LLM_CHUNK_SIZE_VIRTUAL=20
# メタデータ統合フェーズ（OLLAMA）の基本チャンクサイズ
LLM_CHUNK_SIZE_METADATA_OLLAMA=10
# メタデータ統合フェーズ（クラウド系）の基本チャンクサイズ
LLM_CHUNK_SIZE_METADATA_CLOUD=30

# 出力トークン予算に応じたチャンク自動縮小
LLM_CHUNK_ADAPTIVE=true
# 1トラックあたりの想定出力トークン（大きいほどチャンクが小さくなる）
LLM_CHUNK_OUTPUT_TOKENS_PER_TRACK=180
# num_predict に対する安全係数（0.2-0.95）
LLM_CHUNK_OUTPUT_SAFETY_RATIO=0.75

# --- MusicBrainz / AcoustID / Discogs 設定 ---
# MusicBrainz API への問い合わせ時に使用される User-Agent 情報
MBZ_APP_NAME=SST-Scout
MBZ_APP_VERSION=1.0.0
# MusicBrainz 側で問題が発生した際の連絡先メールアドレス
MBZ_CONTACT=contact@example.lan

# AcoustID API Client Key (音声指紋による楽曲特定に使用)
# 取得: https://acoustid.org/my-applications
# ※使用にはシステムに Chromaprint (fpcalc) バイナリのインストールが必要です。
ACOUSTID_API_KEY=

# --- MusicBrainz スコアリング設定 ---
# MusicBrainz から取得した候補の妥当性を評価するためのスコアリング設定（NWO Hybrid Scoring System）
# 各 AppID への直接リンクがある場合の加点
SCORE_MBZ_DIRECT_STEAM_LINK=500
# 親ゲームの AppID へのリンクがある場合の加点
SCORE_MBZ_PARENT_STEAM_LINK=300
# SteamDB への直接リンクがある場合の加点
SCORE_MBZ_DIRECT_STEAMDB_LINK=500
# 親ゲームの SteamDB へのリンクがある場合の加点
SCORE_MBZ_PARENT_STEAMDB_LINK=300
# Bandcamp へのリンクがある場合の加点
SCORE_MBZ_BANDCAMP_LINK=100
# アルバムタイトルの類似度スコア（最大値）
SCORE_MBZ_TITLE_SIMILARITY_MAX=100
# トラック数が完全一致する場合の加点
SCORE_MBZ_TRACK_COUNT_MATCH=50
# トラック数が一致しない場合の1曲あたりの減点（ペナルティ）
SCORE_MBZ_TRACK_COUNT_PENALTY_PER_TRACK=20
# トラック数不一致による減点の最大値
SCORE_MBZ_TRACK_COUNT_PENALTY_MAX=300
# リリースフォーマットが Digital Media である場合の加点
SCORE_MBZ_DIGITAL_FORMAT=30
# リリース年が一致する場合の加点
SCORE_MBZ_DATE_MATCH=20
# リリース年が一致しない場合の1年あたりの減点
SCORE_MBZ_DATE_PENALTY_PER_YEAR=20
# リリース年不一致による減点の最大値
SCORE_MBZ_DATE_PENALTY_MAX=100
# トラック名の 80% 以上がローカルファイルと一致する場合の加点
SCORE_MBZ_FINGERPRINT_MATCH=200
# AcoustID による楽曲の一致（Recording ID）が見つかった場合の加点
SCORE_MBZ_DIRECT_RECORDING_MATCH=1000
# AcoustID によるアルバム全体の一致（Release ID 多数決）が見つかった場合の加点
SCORE_MBZ_ACOUSTID_RELEASE_MATCH=1000
# Steam のパブリッシャーと DB のレーベル名が一致する場合の加点
SCORE_MBZ_PUBLISHER_LABEL_MATCH=100
# MBZ_SEARCH 仮想アルバムにおける、テキスト検索結果を「ノイズ」として足切りする最低スコア（デフォルト: 250）
MIN_MBZ_SEARCH_SCORE_THRESHOLD=250

# --- メタデータ・クリーニング設定 ---
# トラスト・ティア（Trust Tier）設定: 指定したソースから曲名を取得した場合、
# 正規表現による機械的なトラック番号除去（クリーニング）をバイパスします。
# ※公式DBの意図的な数字（例: "1979"）を守るための設定です。
# 推奨: MBZ, PICS_API
TITLE_CLEANING_TRUSTED_SOURCES=MBZ,PICS_API

# --- 通知設定 (Discord Webhook) ---
# Discord 通知機能の有効化 (true: 有効, false: 無効)
NOTIFY_ENABLED=false
# 通知のクールダウン時間（秒）: 同じ種類のエラーを連続して通知しない間隔
NOTIFY_COOLDOWN=60

# 各レベル別 Webhook URL
# Error用: 致命的エラー、システムの停止など
DISCORD_WEBHOOK_CRITICAL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Warning用: レビュー送り、API制限、リトライ失敗など
DISCORD_WEBHOOK_WARNING=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Info用: 個別アルバムの処理完了報告など
DISCORD_WEBHOOK_INFO=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Completion用: 全体処理完了時の最終サマリー
DISCORD_WEBHOOK_COMPLETION=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# --- メタデータ優先順位 ---
# ソースの優先順位をカンマ区切りで指定します。
# MBZ: MusicBrainz (コミュニティによる高精度データ)
# STEAM_PICS: Steam公式構造化データ (PICS API経由。トラックリスト・クレジット・レーベルの正本)
# STEAM_STORE: Steam公式ストアデータ (Store API経由。日本語名・ジャンル)
# STEAM_TAGS: Steam公式ユーザータグ (Web API経由。人気タグ)
# EMBEDDED: 音声ファイル内の既存タグ
# 推奨プリセット: 高精度な公式データを最優先
METADATA_SOURCE_PRIORITY=MBZ,PICS_API,STEAM_STORE,STEAM_TAGS,EMBEDDED

# --- 個別メタデータソース優先順位設定 (Tag-specific Priorities) ---
# 利用可能なソース名:
#   - PICS_API : Steam PICS Bridge API から取得したアルバム/トラック情報
#   - WEB_API  : Steam Web API (store details) からのストアデータ
#   - MBZ      : MusicBrainz API から取得したリリース情報
#   - VDF      : ローカルの appinfo.vdf / ACF マニフェストファイルの情報
#   - EMBED    : 元の音源ファイルに既に埋め込まれているID3等のメタデータ
#   - FILE     : ファイル名やディレクトリ構造などの物理情報
#
# カンマ区切りで左から順に優先して適用されます。値が存在しない場合、自動的に次の優先度のソースへフォールバックします。
# 各項目を未設定にした場合の既定値は src/sst/config.py に集約されており、実装各所で共通に参照されます。

# TIT2 (曲名) の優先順位
# 推奨: 公式DBを優先し、最後に物理情報（FILE, EMBED）を置く
PRIORITY_TIT2=MBZ,PICS_API,FILE,EMBED,VDF
# TPE1 (アーティスト) の優先順位
PRIORITY_TPE1=MBZ,PICS_API,EMBED
# TRCK (トラック番号) の優先順位
PRIORITY_TRCK=PICS_API,MBZ,FILE,EMBED
# TPOS (ディスク番号) の優先順位
PRIORITY_TPOS=PICS_API,EMBED,MBZ
# TYER (発売年) の優先順位
PRIORITY_TYER=MBZ,EMBED,WEB_API
# TPUB (レーベル/パブリッシャー) の優先順位
PRIORITY_TPUB=MBZ,PICS_API
# APIC (カバーアート) の優先順位
PRIORITY_APIC=MBZ,PICS_API,WEB_API,EMBED

# --- 音声フォーマット処理設定 ---
# 優先するオーディオフォーマットの順序 (カンマ区切り、左側が最優先)
# メタデータマージおよびパッケージ採用時、この順番でファイルが優先されます。
# WAV は可逆で最良の音源となり得ますが、メタデータが一切入っていないことが多いため、
# タグ情報を他のファイルからマージ・補完する際に優先度を一番低く設定することが推奨されます。
# 推奨: flac,alac,aiff,wav,mp3,m4a,ogg (可逆を優先し、WAVは最後にフォールバック)
AUDIO_FORMAT_PRIORITY=flac,alac,aiff,wav,mp3,m4a,ogg

# --- システム設定 ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# TimeZone (Asia/Tokyo 等)
TZ=Asia/Tokyo

# --- Performance & Parallel Processing ---
# 全体並列制御
# クラウドAPI利用時の基本並行数。RPMから自動算出された安全な並行数とこの値を比較し、「大きい方」が採用されます。
# (安全値より優先して手動で並行数を底上げしたい場合に使用します)
MAX_PARALLEL_ALBUMS=2


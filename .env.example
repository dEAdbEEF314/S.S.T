# ==============================================================================
# S.S.T (Steam Soundtrack Tagger) 統合設定ファイル
# ==============================================================================

# --- Steam 設定 ---
# Windows側のSteamライブラリのパス (WSL2からのマウントパス形式で指定)
STEAM_LIBRARY_PATH=/mnt/c/SteamLibrary
# 使用言語設定 (ja, en, zh-CN 等、ISO 639-1形式)
USER_LANGUAGE=ja

# --- ローカル処理設定 ---
# 変換やタグ付け作業を行うための一時ディレクトリ (WSL2のネイティブ領域を推奨)
SST_WORKING_DIR=/tmp/sst-work
# 処理状態を記録するSQLiteデータベースのパス
SST_DB_PATH=data/sst_local_state.db

# 並列処理設定 (FFmpeg変換などの音声処理の同時実行数)
MAX_ENCODING_TASKS=4

# --- LLM (Gemini/OpenAI-compatible) 設定 ---
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=your_api_key
# 推奨モデル: gemma-4-31b-it (Google AI Studio)
LLM_MODEL=gemma-4-31b-it
# レート制限 (RPM: 分間リクエスト数, TPM: 分間トークン数, RPD: 日間リクエスト数)
LLM_LIMIT_RPM=15
LLM_LIMIT_TPM=10000000
LLM_LIMIT_RPD=1500

# ローカルLLM強制フラグ (trueの場合、リミッターを解除し、省メモリモードで動作)
LLM_FORCE_LOCAL=false

# --- MusicBrainz 設定 ---
# MusicBrainz API への問い合わせ時に使用される User-Agent 情報
MBZ_APP_NAME=SST-Scout
MBZ_APP_VERSION=0.9.0
# MusicBrainz 側で問題が発生した際の連絡先メールアドレス
MBZ_CONTACT=contact@example.lan

# --- 通知設定 (Discord Webhook) ---
# Discord 通知機能の有効化 (true: 有効, false: 無効)
NOTIFY_ENABLED=false
# 通知のクールダウン時間（秒）: 同じ種類のエラーを連続して通知しない間隔
NOTIFY_COOLDOWN=60

# 各レベル別 Webhook URL
# Error用: 致命的エラー、システムの停止など
DISCORD_WEBHOOK_CRITICAL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Warning用: レビュー送り、API制限、リトライ失敗など
DISCORD_WEBHOOK_WARNING=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Info用: 個別アルバムの処理完了報告など
DISCORD_WEBHOOK_INFO=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Completion用: 全体処理完了時の最終サマリー
DISCORD_WEBHOOK_COMPLETION=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# --- メタデータ優先順位 ---
# ソースの優先順位をカンマ区切りで指定します。
# MBZ: MusicBrainz, STEAM: Steam API, EMBEDDED: 音声ファイルの埋め込みタグ
METADATA_SOURCE_PRIORITY=MBZ,STEAM,EMBEDDED

# --- システム設定 ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Environment mode: development, production
ENV_MODE=production
# TimeZone (Asia/Tokyo 等)
TZ=Asia/Tokyo

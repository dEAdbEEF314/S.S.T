# ==============================================================================
# S.S.T (Steam Soundtrack Tagger) — .gitignore
# ==============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Virtual Environment (uv / venv) ──────────────────────────────────────────
.venv/
venv/
ENV/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/

# ── Environment Variables (CRITICAL — contains API keys & secrets) ────────────
.env
.env.*
!.env.example

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Generated ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
docs/scout_debug.txt
docs/scout_error.txt

# ── Runtime / Generated Data ──────────────────────────────────────────────────
# SQLite databases
*.db

# Scout cache (contains local filesystem paths)
scout_cache.json
scout/scout_cache.json

# LLM usage tracking files (runtime counters)
llm_usage_*.json
scout/llm_usage_*.json

# ── Output & Verification ────────────────────────────────────────────────────
output/
upload/
ui_verification/

# ── AI Tooling (Gemini / Copilot skills) ──────────────────────────────────────
.gemini/
skills/

# ── Local Utility Scripts (not part of the application) ───────────────────────
capture_llm_detail.py
run_production_test.py
delete_list.txt

# ── Root-level package files (not needed — UI deps live in ui/frontend) ───────
/package.json
/package-lock.json

# ── Legacy / Obsolete (referenced in delete_list.txt) ─────────────────────────
prefect.yaml
.prefect/

# ── Project Build Artifacts ───────────────────────────────────────────────────
scout/dist/
scout/build/

.gitignore
.github/
# AI Agent Specific Docs
AGENT_GUIDE.md
docs/AGENT_GUIDE_jp.md
docs/03_ai/agent_prompt.md
docs/03_ai/llm_strategy.md
docs/03_ai/llm_strategy_jp.md
Models/
legacy/
data/
logs/llm_usage_*.json

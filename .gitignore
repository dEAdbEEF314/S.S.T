# ==============================================================================
# S.S.T (Steam Soundtrack Tagger) — .gitignore
# ==============================================================================

# ── Environment Variables (CRITICAL — contains API keys & secrets) ────────────
.env
.env.*
!.env.example

# ── Virtual Environment (uv / venv) ──────────────────────────────────────────
.venv/
venv/
ENV/
scout/.venv/

# ── Runtime / Generated Data ──────────────────────────────────────────────────
# All local databases, caches, and user-specific data
data/
*.db
# Only ignore JSON files in data and logs, keeping schemas and configs
data/*.json
logs/*.json
scout_cache.json
llm_usage_*.json
!data/README.md

# ── Logs ──────────────────────────────────────────────────────────────────────
# All logs produced by the system or libraries
logs/
*.log
docs/scout_debug.txt
docs/scout_error.txt
docs/scout_debug.log
docs/scout_error.log

# ── Output & Packages ────────────────────────────────────────────────────────
# Final processed soundtracks and archives
output/
upload/
ui_verification/
*.zip

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
scout/dist/
scout/build/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Generated ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── AI Tooling (Internal skills and instructions) ───────────────────────────
.gemini/
skills/
# Note: .github/copilot-instructions.md is tracked, so no longer ignored here
# skills/ is kept as ignored if it contains local-only custom skills

# ── Legacy / Obsolete ─────────────────────────────────────────────────────────
legacy/
prefect.yaml
.prefect/
package.json
package-lock.json
capture_llm_detail.py
run_production_test.py
Handover_Document_act-16_20260512.md

# ── Local LLM Blobs ──────────────────────────────────────────────────────────
Models/blobs/

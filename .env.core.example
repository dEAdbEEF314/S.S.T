# ==============================================================================
# Server C (Core, Storage, UI) - Environment Variables
# ==============================================================================

# S3 compatible storage endpoint (Local to this server)
S3_ENDPOINT_URL=http://localhost:8333
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=sst-data
S3_REGION=us-east-1

# Orchestration (Prefect) - Local to this server
PREFECT_API_URL=http://localhost:4200/api

# --- Database (Prefect Backend) ---
POSTGRES_USER=prefect
POSTGRES_PASSWORD=prefect
POSTGRES_DB=prefect

# --- System & Logging ---
LOG_LEVEL=INFO
ENV_MODE=production
TZ=Asia/Tokyo

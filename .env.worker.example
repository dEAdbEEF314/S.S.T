# ==============================================================================
# Server B (Worker Node) - Environment Variables
# ==============================================================================

# S3 compatible storage endpoint (Must point to Server C)
S3_ENDPOINT_URL=http://<SERVER_C_IP>:8333
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=sst-data
S3_REGION=us-east-1

# Orchestration (Prefect) - Must point to Server C
PREFECT_API_URL=http://<SERVER_C_IP>:4200/api

# --- AI / LLM (OpenAI Compatible API) ---
# Note: implementation uses LLM_MODEL, not LLM_MODEL_NAME.
#
# Examples:
#
# [OpenAI]
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxxx...
# LLM_MODEL=gpt-4o
#
# [Gemini (via OpenAI compatibility layer)]
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=your-gemini-api-key
# LLM_MODEL=gemma-3-27b-it
# GEMINI_LIMIT_RPM=30
# GEMINI_LIMIT_TPM=15000
# GEMINI_LLM_LIMIT_RPD=14400
#
# [Ollama]
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1
#
# [Open-WebUI / Local API]
# LLM_BASE_URL=http://<IP>:3000/api
# LLM_API_KEY=sk-xxxx...
# LLM_MODEL=your-favorite-model

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0

# --- External Music Databases ---
MUSICBRAINZ_USER_AGENT="SST/1.0.0 ( contact@example.com )"
ACOUSTID_API_KEY=your_acoustid_api_key

# --- Audio Constraints (Optional) ---
# MAX_SAMPLE_RATE=48000
# MP3_BITRATE=320k

# --- System & Logging ---
LOG_LEVEL=INFO
ENV_MODE=production
TZ=Asia/Tokyo

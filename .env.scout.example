# ==============================================================================
# Server A (Scout Node) - Environment Variables
# ==============================================================================

# Path to the local Steam library (e.g., /mnt/e/SteamLibrary)
STEAM_LIBRARY_PATH=/path/to/your/steamlibrary

# S3 compatible storage endpoint (Must point to Server C)
S3_ENDPOINT_URL=http://<SERVER_C_IP>:8333
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=sst-data
S3_REGION=us-east-1

# Orchestration (Prefect) - Must point to Server C
PREFECT_API_URL=http://<SERVER_C_IP>:4200/api

# --- System & Logging ---
LOG_LEVEL=INFO
ENV_MODE=production
TZ=Asia/Tokyo

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "app_id",
    "file_refs",
    "status",
    "resolved",
    "tag_result",
    "candidate_count",
    "storage"
  ],
  "properties": {
    "app_id": {
      "type": "integer"
    },
    "file_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(archive|review)/.+"
      }
    },
    "status": {
      "type": "string",
      "enum": ["success", "review"]
    },
    "resolved": {
      "type": "object",
      "required": ["resolved", "source"],
      "properties": {
        "resolved": { "type": "boolean" },
        "source": {
          "type": "string",
          "enum": ["vgmdb", "musicbrainz", "steam", "manual"]
        },
        "album": { "type": "string" },
        "artist": { "type": "string" },
        "composer": { "type": "string" },
        "mbid": { "type": "string" },
        "vgmdb_id": { "type": "string" },
        "catalog_number": { "type": "string" },
        "title": { "type": "string" },
        "resolution": { "type": "string" },
        "partial_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "tag_result": {
      "type": "object",
      "required": ["updated", "dry_run"],
      "properties": {
        "updated": { "type": "integer", "minimum": 0 },
        "dry_run": { "type": "boolean" }
      }
    },
    "candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "storage": {
      "type": "object",
      "required": ["bucket", "key"],
      "properties": {
        "bucket": { "type": "string" },
        "key": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
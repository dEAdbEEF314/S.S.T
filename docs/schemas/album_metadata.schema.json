{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SST Album Metadata Schema",
  "description": "Schema for metadata.json generated for each processed album (Act-17).",
  "type": "object",
  "required": [
    "app_id",
    "album_name",
    "status",
    "processed_at",
    "tracks",
    "steam_info"
  ],
  "properties": {
    "app_id": { "type": "integer" },
    "album_name": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["archive", "review", "error", "skip"]
    },
    "processed_at": { "type": "string", "format": "date-time" },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file_path", "original_filename", "tags"],
        "properties": {
          "file_path": { "type": "string" },
          "original_filename": { "type": "string" },
          "tags": { "type": "object" },
          "source": { "type": "string" }
        }
      }
    },
    "steam_info": { 
      "type": "object",
      "properties": {
        "app_id": { "type": "integer" },
        "name": { "type": "string" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "store_tracklist": { "type": "array" },
        "store_credits": { "type": "string" },
        "change_number": { "type": ["integer", "null"] }
      }
    }
  }
}

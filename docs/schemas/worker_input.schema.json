{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["app_id", "files"],
  "properties": {
    "app_id": {
      "type": "integer",
      "minimum": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^ingest/.+"
      }
    }
  },
  "additionalProperties": false
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "app_id",
    "name",
    "install_dir",
    "track_count",
    "files_by_ext",
    "acf_key",
    "uploaded_at",
    "dry_run"
  ],
  "properties": {
    "app_id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "install_dir": {
      "type": "string"
    },
    "storage_location": {
      "type": "string"
    },
    "track_count": {
      "type": "integer",
      "minimum": 0
    },
    "files_by_ext": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "acf_key": {
      "type": "string"
    },
    "uploaded_at": {
      "type": "string",
      "format": "date-time"
    },
    "dry_run": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
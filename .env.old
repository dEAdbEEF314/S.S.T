# ==============================================================================
# S.S.T (Steam Soundtrack Tagger) - Environment Variables Template
# ==============================================================================

# --- Storage (S3 / SeaweedFS) ---
# S3 compatible storage endpoint and credentials
S3_ENDPOINT_URL=http://swfs-s3.outergods.lan:8333
S3_ACCESS_KEY="@5b7u&#irPBiShsH7%5#&rxxZ3C@d$C&"
S3_SECRET_KEY="5Rv87qt7xV^25Kb*y8yrRc@wBYn@*9@9"
S3_BUCKET_NAME=sst-data
S3_REGION=Home-My-Home

# --- Orchestration (Prefect) ---
# Connection settings for Prefect Core container
PREFECT_API_URL=http://localhost:4200/api
# PREFECT_API_KEY=your_prefect_cloud_api_key (Optional: only if using Prefect Cloud)

# --- AI / LLM (OpenAI Compatible API) ---
# Used for title normalization and validation
LLM_API_KEY=sk-1c203634fbfd4f1a81202bff8197cb0c
LLM_BASE_URL=http://open-webui.outergods.lan/api
LLM_MODEL_NAME=recon-steam
LLM_TEMPERATURE=0.0

# --- External Music Databases ---
# MusicBrainz Settings
# User Agent is mandatory for MusicBrainz API calls
MUSICBRAINZ_USER_AGENT=SST-App/0.0.1 ( deadbeef314@gmail.com )

# AcoustID API Key (Required for fingerprinting)
ACOUSTID_API_KEY=sIFKOUL6kC

# --- Steam Library (Scout Container) ---
# Path to the local Steam library (e.g., /mnt/e/SteamLibrary)
# This directory must contain 'steamapps/common' and ACF files.
STEAM_LIBRARY_PATH=/mnt/d/SteamLibrary

# --- System & Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
# Environment mode: development, production
ENV_MODE=development

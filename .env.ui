# ==============================================================================
# Server A (Scout Node) - Environment Variables
# ==============================================================================

# Path to the local Steam library
STEAM_LIBRARY_PATH=/mnt/d/SteamLibrary

# S3 compatible storage endpoint (Must point to Server C / Storage)
S3_ENDPOINT_URL=http://swfs-s3.outergods.lan
S3_ACCESS_KEY="katsudontabetai"
S3_SECRET_KEY="oyakodontabetai"
S3_BUCKET_NAME=sst-data
S3_REGION=Home-My-Home

# Orchestration (Prefect) - Must point to Server C
PREFECT_API_URL=http://prefect.outergods.lan/api

# --- System & Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
# Environment mode: development, production
ENV_MODE=development

TZ=Asia/Tokyo
PREFECT_FLOW_NAME=SST-Production-Pipeline
